{
  "compilerOptions": {
    "target": "es2016",
    "jsx": "react-jsx",
    "jsxImportSource": "@tiendanube/nube-sdk-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true
  },
  "include": ["./src/**/*"]
}
