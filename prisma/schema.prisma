generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum StoreStatus {
  CONNECTED
  DISCONNECTED
  SUSPENDED
}

enum BundleStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum BundleItemRole {
  PRIMARY
  COMPLEMENT
  OPTIONAL
}

enum DiscountType {
  NONE
  PERCENTAGE
  FIXED_AMOUNT
}

enum WebhookEventStatus {
  RECEIVED
  PROCESSED
  FAILED
  SKIPPED
}

enum AuditActorType {
  SYSTEM
  STORE_USER
  WEBHOOK
}

model Store {
  id                    String           @id @default(cuid())
  nuvemshopStoreId      String?          @unique @map("nuvemshop_id")
  name                  String?
  accessTokenCiphertext String?          @map("access_token_encrypted")
  createdAt             DateTime         @default(now()) @map("created_at")
  updatedAt             DateTime         @updatedAt @map("updated_at")
  disconnectedAt        DateTime?        @map("disconnected_at")
  products              Product[]
  variants              ProductVariant[]
  bundles               Bundle[]
  crossSellOffers       CrossSellOffer[]
  webhookEvents         WebhookEvent[]
  auditLogs             AuditLog[]

  @@map("stores")
}

model Product {
  id                 String           @id @default(cuid())
  storeId            String
  nuvemshopProductId String
  name               String
  handle             String?
  imageUrl           String?          @db.Text
  status             String?
  published          Boolean          @default(true)
  importedAt         DateTime         @default(now())
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  store              Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  variants           ProductVariant[]
  bundleItems        BundleItem[]

  @@unique([storeId, nuvemshopProductId])
  @@index([storeId, name])
}

model ProductVariant {
  id                 String       @id @default(cuid())
  storeId            String
  productId          String
  nuvemshopVariantId String
  name               String?
  sku                String?
  price              Decimal?     @db.Decimal(12, 2)
  compareAtPrice     Decimal?     @db.Decimal(12, 2)
  stock              Int?
  available          Boolean      @default(true)
  importedAt         DateTime     @default(now())
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  store              Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product            Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  bundleItems        BundleItem[]

  @@unique([storeId, nuvemshopVariantId])
  @@index([productId])
  @@index([storeId, sku])
}

model Bundle {
  id            String       @id @default(cuid())
  storeId       String
  title         String
  slug          String?
  status        BundleStatus @default(DRAFT)
  discountType  DiscountType @default(NONE)
  discountValue Decimal?     @db.Decimal(12, 2)
  startsAt      DateTime?
  endsAt        DateTime?
  priority      Int          @default(0)
  settings      Json?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  store         Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  items         BundleItem[]

  @@unique([storeId, slug])
  @@index([storeId, status])
  @@index([storeId, priority])
}

model BundleItem {
  id            String          @id @default(cuid())
  bundleId      String
  productId     String
  variantId     String?
  role          BundleItemRole  @default(COMPLEMENT)
  quantity      Int             @default(1)
  sortOrder     Int             @default(0)
  discountType  DiscountType    @default(NONE)
  discountValue Decimal?        @db.Decimal(12, 2)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  bundle        Bundle          @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  product       Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant       ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([bundleId, sortOrder])
  @@index([productId])
  @@index([variantId])
}

model CrossSellOffer {
  id                   String                  @id @default(cuid())
  storeId              String
  suggestedProductId   String
  suggestedProductName String
  isActive             Boolean                 @default(true)
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  store                Store                   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  triggers             CrossSellOfferTrigger[]

  @@index([storeId, isActive])
  @@index([storeId, createdAt])
}

model CrossSellOfferTrigger {
  id                 String         @id @default(cuid())
  offerId            String
  triggerProductId   String
  triggerProductName String
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  offer              CrossSellOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@unique([offerId, triggerProductId])
  @@index([offerId])
}

model WebhookEvent {
  id               String             @id @default(cuid())
  storeId          String?
  provider         String             @default("nuvemshop")
  topic            String
  resourceId       String?
  deduplicationKey String             @unique
  status           WebhookEventStatus @default(RECEIVED)
  attempts         Int                @default(0)
  payload          Json
  errorMessage     String?            @db.Text
  receivedAt       DateTime           @default(now())
  processedAt      DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  store            Store?             @relation(fields: [storeId], references: [id], onDelete: SetNull)

  @@index([storeId, topic])
  @@index([status, receivedAt])
}

model AuditLog {
  id         String         @id @default(cuid())
  storeId    String?
  actorType  AuditActorType @default(SYSTEM)
  actorId    String?
  action     String
  entityType String?
  entityId   String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?        @db.Text
  createdAt  DateTime       @default(now())
  store      Store?         @relation(fields: [storeId], references: [id], onDelete: SetNull)

  @@index([storeId, createdAt])
  @@index([action])
  @@index([entityType, entityId])
}
